# Example environment variables for running integration tests.
# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and will never be committed.

# Required
PMCE_API_KEY=your-api-key

# Optional - defaults to OpenAI
PMCE_BASE_URL=https://api.openai.com/v1
PMCE_MODEL=gpt-4o-mini
PMCE_PROVIDER=

# MiniMax M3 example:
# PMCE_BASE_URL=https://api.minimax.chat/v1
# PMCE_MODEL=minimax-m3
# PMCE_PROVIDER=minimax
